# PostgreSQL connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/codenexsis?schema=public"

# JWT
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
# Comma-separated list of allowed origins (website + admin dashboard)
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# First admin (used by the seed script)
ADMIN_EMAIL="admin@codenexsis.com"
ADMIN_PASSWORD="Admin@12345"
ADMIN_NAME="Codenexsis Admin"
